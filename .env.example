# OpenAI
OPENAI_API_KEY=sk-your-key-here
# gpt-4o-mini = fast & cheap | gpt-4o = smarter (recommended for complex sales Q&A)
OPENAI_MODEL=gpt-4o-mini

# Meta WhatsApp Cloud API
# From: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id-from-meta-api-setup
VERIFY_TOKEN=pick-any-random-secret-string-you-choose

# Server
PORT=3000
NODE_ENV=production

# Company (optional override)
COMPANY_NAME=Mysogi
