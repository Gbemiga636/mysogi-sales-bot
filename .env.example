# gpt-4o = smartest & most accurate (recommended) | gpt-4o-mini = cheaper
OPENAI_MODEL=gpt-4o

# Mr Odun escalation — sales team messages forwarded here
MR_ODUN_PHONE=2348087965610
MR_ODUN_DISPLAY=+234 808 796 5610

# Meta WhatsApp Cloud API
# From: developers.facebook.com → Your App → WhatsApp → API Setup
